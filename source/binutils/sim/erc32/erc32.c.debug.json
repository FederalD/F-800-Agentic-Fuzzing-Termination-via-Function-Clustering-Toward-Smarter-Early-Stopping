      "fn_code": "static void\nchk_irq()\n{\n    int32           i;\n    uint32          itmp;\n    int\t\t    old_irl;\n\n    old_irl = ext_irl;\n    if (mec_tcr & 0x80000) itmp = mec_ifr;\n    else itmp  = 0;\n    itmp = ((mec_ipr | itmp) & ~mec_imr) & 0x0fffe;\n    ext_irl = 0;\n    if (itmp != 0) {\n\tfor (i = 15; i > 0; i--) {\n\t    if (((itmp >> i) & 1) != 0) {\n\t\tif ((sis_verbose) && (i > old_irl)) \n\t\t    printf(\"IU irl: %d\\n\", i);\n\t\text_irl = i;\n\t        set_int(i, mec_intack, i);\n\t\tbreak;\n\t    }\n\t}\n    }\n}",
