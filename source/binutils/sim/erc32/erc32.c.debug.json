      "fn_code": "static void\nstore_bytes (unsigned char *mem, uint32 waddr, uint32 *data, int32 sz,\n\t     int32 *ws)\n{\n    switch (sz) {\n\tcase 0:\n\t    waddr ^= EBT;\n\t    mem[waddr] = *data & 0x0ff;\n\t    *ws = mem_ramw_ws + 3;\n\t    break;\n\tcase 1:\n#ifdef HOST_LITTLE_ENDIAN\n\t    waddr ^= 2;\n#endif\n\t    memcpy (&mem[waddr], data, 2);\n\t    *ws = mem_ramw_ws + 3;\n\t    break;\n\tcase 2:\n\t    memcpy (&mem[waddr], data, 4);\n\t    *ws = mem_ramw_ws;\n\t    break;\n\tcase 3:\n\t    memcpy (&mem[waddr], data, 8);\n\t    *ws = 2 * mem_ramw_ws + STD_WS;\n\t    break;\n    }\n}",
