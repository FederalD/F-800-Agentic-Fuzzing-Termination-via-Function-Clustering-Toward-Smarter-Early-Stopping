      "fn_code": "static void\ndecode_ersr()\n{\n    if (mec_ersr & 0x01) {\n\tif (!(mec_mcr & 0x20)) {\n\t    if (mec_mcr & 0x40) {\n\t        sys_reset();\n\t        mec_ersr = 0x8000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager reset - IU in error mode\\n\");\n\t    } else {\n\t        sys_halt();\n\t        mec_ersr |= 0x2000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager halt - IU in error mode\\n\");\n\t    }\n\t} else\n\t    mec_irq(1);\n    }\n    if (mec_ersr & 0x04) {\n\tif (!(mec_mcr & 0x200)) {\n\t    if (mec_mcr & 0x400) {\n\t        sys_reset();\n\t        mec_ersr = 0x8000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager reset - IU comparison error\\n\");\n\t    } else {\n\t        sys_halt();\n\t        mec_ersr |= 0x2000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager halt - IU comparison error\\n\");\n\t    }\n\t} else\n\t    mec_irq(1);\n    }\n    if (mec_ersr & 0x20) { \n\tif (!(mec_mcr & 0x2000)) {\n\t    if (mec_mcr & 0x4000) {\n\t        sys_reset();\n\t        mec_ersr = 0x8000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager reset - MEC hardware error\\n\");\n\t    } else {\n\t        sys_halt();\n\t        mec_ersr |= 0x2000;\n\t        if (sis_verbose)\n\t            printf(\"Error manager halt - MEC hardware error\\n\");\n\t    }\n\t} else\n\t    mec_irq(1);\n    }\n}",
