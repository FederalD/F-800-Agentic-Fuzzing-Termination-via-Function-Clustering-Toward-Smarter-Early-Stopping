      "fn_code": "static const char *\ndecode_cpsr (FlagMask flags)\n{\n  switch (flags & CPSR_ALL_FLAGS)\n    {\n    default:\n    case 0:  return \"----\";\n    case 1:  return \"---V\";\n    case 2:  return \"--C-\";\n    case 3:  return \"--CV\";\n    case 4:  return \"-Z--\";\n    case 5:  return \"-Z-V\";\n    case 6:  return \"-ZC-\";\n    case 7:  return \"-ZCV\";\n    case 8:  return \"N---\";\n    case 9:  return \"N--V\";\n    case 10: return \"N-C-\";\n    case 11: return \"N-CV\";\n    case 12: return \"NZ--\";\n    case 13: return \"NZ-V\";\n    case 14: return \"NZC-\";\n    case 15: return \"NZCV\";\n    }\n}",
      "fn_code_pos": [
