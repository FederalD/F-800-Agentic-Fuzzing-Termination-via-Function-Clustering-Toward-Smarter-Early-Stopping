      "fn_code": "void\naarch64_set_CPSR_bits (sim_cpu *cpu, uint32_t mask, uint32_t value)\n{\n  uint32_t old_flags = cpu->CPSR;\n\n  mask &= CPSR_ALL_FLAGS;\n  cpu->CPSR &= ~ mask;\n  cpu->CPSR |= (value & mask);\n\n  if (old_flags != cpu->CPSR)\n    TRACE_REGISTER (cpu,\n\t\t    \"CPSR changes from %s to %s\",\n\t\t    decode_cpsr (old_flags), decode_cpsr (cpu->CPSR));\n}",
