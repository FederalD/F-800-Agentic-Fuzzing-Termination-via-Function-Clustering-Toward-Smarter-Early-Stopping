      "fn_code": "void\nhw_free (struct hw *me,\n\t void *alloc)\n{\n  struct hw_alloc_data **memory;\n  for (memory = &me->alloc_of_hw;\n       *memory != NULL;\n       memory = &(*memory)->next)\n    {\n      if ((*memory)->alloc == alloc)\n\t{\n\t  struct hw_alloc_data *die = (*memory);\n\t  (*memory) = die->next;\n\t  free (die->alloc);\n\t  free (die);\n\t  return;\n\t}\n    }\n  hw_abort (me, \"free of memory not belonging to a device\");\n}",
