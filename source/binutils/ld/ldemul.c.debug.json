    {
      "fn_code": "void\nldemul_list_emulations (FILE *f)\n{\n  ld_emulation_xfer_type **eptr = ld_emulations;\n  bfd_boolean first = TRUE;\n\n  for (; *eptr; eptr++)\n    {\n      if (first)\n\tfirst = FALSE;\n      else\n\tfprintf (f, \" \");\n      fprintf (f, \"%s\", (*eptr)->emulation_name);\n    }\n}",
