      "fn_code": "char *\ntmpnam (char *s)\n{\n  int pid = getpid ();\n\n  if (s == NULL)\n    s = tmpnam_buffer;\n\n  /*  Generate the filename and make sure that there isn't one called\n      it already.  */\n\n  while (1)\n    {\n      FILE *f;\n      sprintf (s, \"%s/%s%x.%x\", P_tmpdir, \"t\", pid, tmpnam_counter);\n      f = fopen (s, \"r\");\n      if (f == NULL)\n\tbreak;\n      tmpnam_counter++;\n      fclose (f);\n    }\n\n  return s;\n}",
