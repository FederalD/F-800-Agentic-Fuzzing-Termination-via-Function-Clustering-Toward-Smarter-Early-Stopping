      "fn_code": "const char *\ndos_lbasename (const char *name)\n{\n  const char *base;\n\n  /* Skip over a possible disk name.  */\n  if (ISALPHA (name[0]) && name[1] == ':') \n    name += 2;\n\n  for (base = name; *name; name++)\n    if (IS_DOS_DIR_SEPARATOR (*name))\n      base = name + 1;\n\n  return base;\n}",
