      "fn_code": "char *\nbasename (const char *name)\n{\n  const char *base;\n\n#if defined (HAVE_DOS_BASED_FILE_SYSTEM)\n  /* Skip over the disk name in MSDOS pathnames. */\n  if (ISALPHA (name[0]) && name[1] == ':') \n    name += 2;\n#endif\n\n  for (base = name; *name; name++)\n    {\n      if (IS_DIR_SEPARATOR (*name))\n\t{\n\t  base = name + 1;\n\t}\n    }\n  return (char *) base;\n}",
