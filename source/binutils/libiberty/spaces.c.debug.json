      "fn_code": "const char *\nspaces (int count)\n{\n  register char *t;\n  static char *buf;\n  static int maxsize;\n\n  if (count > maxsize)\n    {\n      free (buf);\n      buf = (char *) malloc (count + 1);\n      if (buf == (char *) 0)\n\treturn 0;\n      for (t = buf + count ; t != buf ; )\n\t{\n\t  *--t = ' ';\n\t}\n      maxsize = count;\n      buf[count] = '\\0';\n    }\n  return (const char *) (buf + maxsize - count);\n}",
