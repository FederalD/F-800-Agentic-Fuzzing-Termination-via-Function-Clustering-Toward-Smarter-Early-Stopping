      "fn_code": "int fdmatch (int fd1, int fd2)\n{\n  struct stat sbuf1;\n  struct stat sbuf2;\n\n  if ((fstat (fd1, &sbuf1) == 0) &&\n      (fstat (fd2, &sbuf2) == 0) &&\n      (sbuf1.st_dev == sbuf2.st_dev) &&\n      (sbuf1.st_ino == sbuf2.st_ino))\n    {\n      return (1);\n    }\n  else\n    {\n      return (0);\n    }\n}",
