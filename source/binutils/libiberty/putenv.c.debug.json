      "fn_code": "int\nputenv (const char *string)\n{\n  const char *const name_end = strchr (string, '=');\n\n  if (name_end)\n    {\n      char *name = (char *) alloca (name_end - string + 1);\n      memcpy (name, string, name_end - string);\n      name[name_end - string] = '\\0';\n      return setenv (name, name_end + 1, 1);\n    }\n\n  unsetenv (string);\n  return 0;\n}",
