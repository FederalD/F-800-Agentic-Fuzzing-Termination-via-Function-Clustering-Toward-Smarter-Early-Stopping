    {
      "fn_code": "static void\nmaintenance_print_reggroups (char *args, int from_tty)\n{\n  struct gdbarch *gdbarch = get_current_arch ();\n\n  if (args == NULL)\n    reggroups_dump (gdbarch, gdb_stdout);\n  else\n    {\n      stdio_file file;\n\n      if (!file.open (args, \"w\"))\n\tperror_with_name (_(\"maintenance print reggroups\"));\n      reggroups_dump (gdbarch, &file);\n    }\n}",
