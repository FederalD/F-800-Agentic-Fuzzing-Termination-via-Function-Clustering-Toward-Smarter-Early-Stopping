      "fn_code": "void\nx86_forget_process (pid_t pid)\n{\n  struct x86_process_info *proc, **proc_link;\n\n  proc = x86_process_list;\n  proc_link = &x86_process_list;\n\n  while (proc != NULL)\n    {\n      if (proc->pid == pid)\n\t{\n\t  *proc_link = proc->next;\n\n\t  xfree (proc);\n\t  return;\n\t}\n\n      proc_link = &proc->next;\n      proc = *proc_link;\n    }\n}",
