      "fn_code": "void\nremove_inferior (struct inferior_list *list,\n\t\t struct inferior_list_entry *entry)\n{\n  struct inferior_list_entry **cur;\n\n  if (list->head == entry)\n    {\n      list->head = entry->next;\n      if (list->tail == entry)\n\tlist->tail = list->head;\n      return;\n    }\n\n  cur = &list->head;\n  while (*cur && (*cur)->next != entry)\n    cur = &(*cur)->next;\n\n  if (*cur == NULL)\n    return;\n\n  (*cur)->next = entry->next;\n\n  if (list->tail == entry)\n    list->tail = *cur;\n}",
