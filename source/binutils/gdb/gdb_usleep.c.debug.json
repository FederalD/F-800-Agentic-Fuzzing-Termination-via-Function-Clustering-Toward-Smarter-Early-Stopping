      "fn_code": "int\ngdb_usleep (int usec)\n{\n  struct timeval delay;\n  int retval;\n\n  delay.tv_sec = usec / 1000000;\n  delay.tv_usec = usec % 1000000;\n  retval = gdb_select (0, 0, 0, 0, &delay);\n\n  if (retval < 0)\n    retval = -1;\n  else\n    retval = 0;\n\n  return retval;\n}",
