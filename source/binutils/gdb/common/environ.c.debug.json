      "fn_code": "const char *\ngdb_environ::get (const char *var) const\n{\n  size_t len = strlen (var);\n\n  for (char *el : m_environ_vector)\n    if (el != NULL && match_var_in_string (el, var, len))\n      return &el[len + 1];\n\n  return NULL;\n}",
