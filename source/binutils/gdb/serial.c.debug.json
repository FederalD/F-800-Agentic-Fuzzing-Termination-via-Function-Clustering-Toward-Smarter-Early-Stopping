      "fn_code": "static struct serial *\nserial_fdopen_ops (const int fd, const struct serial_ops *ops)\n{\n  struct serial *scb;\n\n  if (!ops)\n    {\n      ops = serial_interface_lookup (\"terminal\");\n      if (!ops)\n \tops = serial_interface_lookup (\"hardwire\");\n    }\n\n  if (!ops)\n    return NULL;\n\n  scb = new_serial (ops);\n\n  scb->next = scb_base;\n  scb_base = scb;\n\n  if ((ops->fdopen) != NULL)\n    (*ops->fdopen) (scb, fd);\n  else\n    scb->fd = fd;\n\n  return scb;\n}",
