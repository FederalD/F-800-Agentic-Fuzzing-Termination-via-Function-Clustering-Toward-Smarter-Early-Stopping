      "fn_code": "static const struct serial_ops *\nserial_interface_lookup (const char *name)\n{\n  const struct serial_ops *ops;\n  int i;\n\n  for (i = 0; VEC_iterate (serial_ops_p, serial_ops_list, i, ops); ++i)\n    if (strcmp (name, ops->name) == 0)\n      return ops;\n\n  return NULL;\n}",
