      "fn_code": "void\ncli_ui_out::do_field_string (int fldno, int width, ui_align align,\n\t\t\t     const char *fldname, const char *string)\n{\n  int before = 0;\n  int after = 0;\n\n  if (m_suppress_output)\n    return;\n\n  if ((align != ui_noalign) && string)\n    {\n      before = width - strlen (string);\n      if (before <= 0)\n\tbefore = 0;\n      else\n\t{\n\t  if (align == ui_right)\n\t    after = 0;\n\t  else if (align == ui_left)\n\t    {\n\t      after = before;\n\t      before = 0;\n\t    }\n\t  else\n\t    /* ui_center */\n\t    {\n\t      after = before / 2;\n\t      before -= after;\n\t    }\n\t}\n    }\n\n  if (before)\n    spaces (before);\n\n  if (string)\n    out_field_fmt (fldno, fldname, \"%s\", string);\n\n  if (after)\n    spaces (after);\n\n  if (align != ui_noalign)\n    field_separator ();\n}",
