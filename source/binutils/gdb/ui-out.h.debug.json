    "9e40e3673ad3069566949c4e53c7b685c94033d5aa902e0b5bc65849ecee321c": {
      "class_code": "template<ui_out_type Type>\nclass ui_out_emit_type\n{\npublic:\n\n  ui_out_emit_type (struct ui_out *uiout, const char *id)\n    : m_uiout (uiout)\n  {\n    uiout->begin (Type, id);\n  }\n\n  ~ui_out_emit_type ()\n  {\n    m_uiout->end (Type);\n  }\n\n  ui_out_emit_type (const ui_out_emit_type<Type> &) = delete;\n  ui_out_emit_type<Type> &operator= (const ui_out_emit_type<Type> &)\n      = delete;\n\nprivate:\n\n  struct ui_out *m_uiout;\n};",
