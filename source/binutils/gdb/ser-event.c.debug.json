      "fn_code": "static void\nserial_event_close (struct serial *scb)\n{\n  struct serial_event_state *state = (struct serial_event_state *) scb->state;\n\n  close (scb->fd);\n#ifndef USE_WIN32API\n  close (state->write_fd);\n#else\n  CloseHandle (state->event);\n#endif\n\n  scb->fd = -1;\n\n  xfree (state);\n  scb->state = NULL;\n}",
