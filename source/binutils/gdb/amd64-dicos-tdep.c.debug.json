    {
      "fn_code": "void\n_initialize_amd64_dicos_tdep (void)\n{\n  gdbarch_register_osabi_sniffer (bfd_arch_i386, bfd_target_elf_flavour,\n\t\t\t\t  amd64_dicos_osabi_sniffer);\n\n  gdbarch_register_osabi (bfd_arch_i386, bfd_mach_x86_64,\n\t\t\t  GDB_OSABI_DICOS,\n\t\t\t  amd64_dicos_init_abi);\n}",
