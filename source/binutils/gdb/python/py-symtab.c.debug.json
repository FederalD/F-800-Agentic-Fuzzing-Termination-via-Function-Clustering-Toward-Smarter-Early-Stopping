      "fn_code": "static void\nset_symtab (symtab_object *obj, struct symtab *symtab)\n{\n  obj->symtab = symtab;\n  obj->prev = NULL;\n  if (symtab)\n    {\n      obj->next\n\t= ((struct stpy_symtab_object *)\n\t   objfile_data (SYMTAB_OBJFILE (symtab), stpy_objfile_data_key));\n      if (obj->next)\n\tobj->next->prev = obj;\n      set_objfile_data (SYMTAB_OBJFILE (symtab), stpy_objfile_data_key, obj);\n    }\n  else\n    obj->next = NULL;\n}",
