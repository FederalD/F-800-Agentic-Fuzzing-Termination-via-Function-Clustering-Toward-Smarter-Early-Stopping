      "fn_code": "static void\ndel_objfile_blocks (struct objfile *objfile, void *datum)\n{\n  block_object *obj = (block_object *) datum;\n\n  while (obj)\n    {\n      block_object *next = obj->next;\n\n      obj->block = NULL;\n      obj->objfile = NULL;\n      obj->next = NULL;\n      obj->prev = NULL;\n\n      obj = next;\n    }\n}",
