      "fn_code": "static void\nblpy_dealloc (PyObject *obj)\n{\n  block_object *block = (block_object *) obj;\n\n  if (block->prev)\n    block->prev->next = block->next;\n  else if (block->objfile)\n    {\n      set_objfile_data (block->objfile, blpy_objfile_data_key,\n\t\t\tblock->next);\n    }\n  if (block->next)\n    block->next->prev = block->prev;\n  block->block = NULL;\n}",
