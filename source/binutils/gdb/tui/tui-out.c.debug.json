      "fn_code": "void\ntui_ui_out::do_text (const char *string)\n{\n  if (suppress_output ())\n    return;\n\n  m_start_of_line++;\n  if (m_line > 0)\n    {\n      if (strchr (string, '\\n') != 0)\n        {\n          m_line = -1;\n          m_start_of_line = 0;\n        }\n      return;\n    }\n  if (strchr (string, '\\n'))\n    m_start_of_line = 0;\n\n  cli_ui_out::do_text (string);\n}",
