      "fn_code": "char *\nnbsd_pid_to_exec_file (struct target_ops *self, int pid)\n{\n  ssize_t len;\n  static char buf[PATH_MAX];\n  char name[PATH_MAX];\n\n  xsnprintf (name, PATH_MAX, \"/proc/%d/exe\", pid);\n  len = readlink (name, buf, PATH_MAX - 1);\n  if (len != -1)\n    {\n      buf[len] = '\\0';\n      return buf;\n    }\n\n  return NULL;\n}",
