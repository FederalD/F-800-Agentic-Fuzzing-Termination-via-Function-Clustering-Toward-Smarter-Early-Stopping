    {
      "fn_code": "void\n_initialize_i386_dicos_tdep (void)\n{\n  gdbarch_register_osabi_sniffer (bfd_arch_i386, bfd_target_elf_flavour,\n                                  i386_dicos_osabi_sniffer);\n\n  gdbarch_register_osabi (bfd_arch_i386, 0, GDB_OSABI_DICOS,\n                          i386_dicos_init_abi);\n}",
