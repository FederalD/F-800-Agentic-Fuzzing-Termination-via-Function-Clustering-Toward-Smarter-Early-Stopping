      "fn_code": "int gzfilebuf::fillbuf() {\n\n  int required;\n  char *p;\n\n  p = base();\n\n  required = blen();\n\n  int t = gzread( file, p, required );\n\n  if ( t <= 0) return EOF;\n\n  setg( base(), base(), base()+t);\n\n  return t;\n\n}",
