      "fn_code": "int gzfilebuf::flushbuf() {\n\n  int n;\n  char *q;\n\n  q = pbase();\n  n = pptr() - q;\n\n  if ( gzwrite( file, q, n) < n )\n    return EOF;\n\n  setp(0,0);\n\n  return 0;\n\n}",
