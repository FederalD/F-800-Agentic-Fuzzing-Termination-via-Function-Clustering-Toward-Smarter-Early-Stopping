      "class_code": "class Set_target_once : public Once\n{\n public:\n  Set_target_once(Target_selector* target_selector)\n    : target_selector_(target_selector)\n  { }\n\n protected:\n  void\n  do_run_once(void*);\n\n private:\n  Target_selector* target_selector_;\n}",
