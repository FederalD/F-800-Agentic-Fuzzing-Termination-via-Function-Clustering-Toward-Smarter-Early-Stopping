      "class_code": "template<typename Obj>\nclass Task_lock_obj\n{\n public:\n  Task_lock_obj(const Task* task, Obj* obj)\n    : task_(task), obj_(obj)\n  { this->obj_->lock(task); }\n\n  ~Task_lock_obj()\n  { this->obj_->unlock(this->task_); }\n\n private:\n  Task_lock_obj(const Task_lock_obj&);\n  Task_lock_obj& operator=(const Task_lock_obj&);\n\n  const Task* task_;\n  Obj* obj_;\n};",
