      "class_code": "class Lock\n{\n public:\n  Lock();\n\n  ~Lock();\n\n  // Acquire the lock.\n  void\n  acquire()\n  { this->lock_->acquire(); }\n\n  // Release the lock.\n  void\n  release()\n  { this->lock_->release(); }\n\n private:\n  // This class can not be copied.\n  Lock(const Lock&);\n  Lock& operator=(const Lock&);\n\n  friend class Condvar;\n  Lock_impl*\n  get_impl() const\n  { return this->lock_; }\n\n  Lock_impl* lock_;\n}",
