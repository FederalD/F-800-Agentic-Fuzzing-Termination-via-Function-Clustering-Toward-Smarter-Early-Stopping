      "fn_code": "static void\nMY (choose_reloc_size) (bfd *abfd)\n{\n  switch (bfd_get_arch (abfd))\n    {\n    case bfd_arch_sparc:\n    case bfd_arch_mips:\n      obj_reloc_entry_size (abfd) = RELOC_EXT_SIZE;\n      break;\n    default:\n      obj_reloc_entry_size (abfd) = RELOC_STD_SIZE;\n      break;\n    }\n}",
