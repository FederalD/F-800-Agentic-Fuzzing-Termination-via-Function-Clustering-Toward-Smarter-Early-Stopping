      "fn_code": "static void\ndo_fancy_stuff ()\n{\n  unsigned int idx = 0;\n  string_type out;\n  init_string (&out);\n  while (at (tos, idx))\n    {\n      if (at (tos, idx) == '<'\n\t  && at (tos, idx + 1) == '<'\n\t  && !isspace ((unsigned char) at (tos, idx + 2)))\n\t{\n\t  /* This qualifies as a << startup.  */\n\t  idx += 2;\n\t  cattext (&out, \"@code{\");\n\t  while (at (tos, idx)\n\t\t && at (tos, idx) != '>' )\n\t    {\n\t      catchar (&out, at (tos, idx));\n\t      idx++;\n\n\t    }\n\t  cattext (&out, \"}\");\n\t  idx += 2;\n\t}\n      else\n\t{\n\t  catchar (&out, at (tos, idx));\n\t  idx++;\n\t}\n    }\n  delete_string (tos);\n  *tos = out;\n  pc++;\n\n}",
