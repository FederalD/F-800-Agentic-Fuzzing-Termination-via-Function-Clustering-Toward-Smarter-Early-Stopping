      "fn_code": "static void\ntranslatecomments ()\n{\n  unsigned int idx = 0;\n  string_type out;\n  init_string (&out);\n\n  while (at (tos, idx))\n    {\n      if (at (tos, idx) == '{' && at (tos, idx + 1) == '*')\n\t{\n\t  cattext (&out, \"/*\");\n\t  idx += 2;\n\t}\n      else if (at (tos, idx) == '*' && at (tos, idx + 1) == '}')\n\t{\n\t  cattext (&out, \"*/\");\n\t  idx += 2;\n\t}\n      else\n\t{\n\t  catchar (&out, at (tos, idx));\n\t  idx++;\n\t}\n    }\n\n  overwrite_string (tos, &out);\n\n  pc++;\n}",
