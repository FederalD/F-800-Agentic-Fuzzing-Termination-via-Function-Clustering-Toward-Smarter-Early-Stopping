      "fn_code": "char *\nrl_gets ()\n{\n  /* If the buffer has already been allocated, return the memory\n     to the free pool. */\n  if (line_read)\n    {\n      free (line_read);\n      line_read = (char *)NULL;\n    }\n\n  /* Get a line from the user. */\n  line_read = readline (\"\");\n\n  /* If the line has any text in it, save it on the history. */\n  if (line_read && *line_read)\n    add_history (line_read);\n\n  return (line_read);\n}",
