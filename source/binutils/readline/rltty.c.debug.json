    {
      "fn_code": "int\n_rl_restore_tty_signals ()\n{\n  int r;\n\n  if (tty_sigs_disabled == 0)\n    return 0;\n\n  r = _set_tty_settings (fileno (rl_instream), &sigstty);\n\n  if (r == 0)\n    tty_sigs_disabled = 0;\n\n  return r;\n}",
